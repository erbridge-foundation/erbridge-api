# Copy this file to .env and fill in the values.
# .env is loaded automatically on startup via dotenvy.

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgres://erbridge:password@localhost:5432/erbridge

# Public-facing base URL (no trailing slash)
APP_URL=http://localhost:8080

# Source secret for AES-256-GCM encryption and HS256 JWT signing.
# Generate with: openssl rand -hex 32
ENCRYPTION_SECRET=replace_me_with_output_of_openssl_rand_hex_32

# EVE SSO application credentials — register at https://developers.eveonline.com/
# Set the callback URL to: http://localhost:8080/auth/callback
ESI_CLIENT_ID=your_esi_client_id
ESI_CLIENT_SECRET=your_esi_client_secret

# ── Optional ──────────────────────────────────────────────────────────────────

# OAuth callback URL (defaults to APP_URL/auth/callback)
# ESI_CALLBACK_URL=http://localhost:8080/auth/callback

# Post-login redirect URL (defaults to APP_URL)
# FRONTEND_URL=http://localhost:5173

# Image cache directory (defaults to $TMPDIR/erbridge-images)
# IMAGE_CACHE_DIR=/tmp/erbridge-images

# Days before a pending-delete account is hard-deleted (default: 30)
# ACCOUNT_DELETION_GRACE_DAYS=30

# ESI base URL — override for testing against a mock
# ESI_BASE_URL=https://esi.evetech.net/latest

# Maximum age of a refresh token before re-auth is required (default: 7 days)
# ESI_REFRESH_TOKEN_MAX_DAYS=7

# Online poller — characters per batch and minimum delay between batches
# ESI_POLL_BATCH_SIZE=10
# ESI_POLL_BATCH_DELAY_MS=500

# Location poller — max concurrent ESI requests
# ESI_POLL_CONCURRENCY=10

# How often the map checkpoint task runs, in minutes (default: 60)
# MAP_CHECKPOINT_INTERVAL_MINS=60

# Logging filter (default: erbridge_api=info)
# RUST_LOG=erbridge_api=debug

# ── Multi-client ESI pool (optional, overrides single client above) ───────────
# Use when you want to spread OAuth load across multiple registered applications.
# N starts at 1 and must be contiguous.
# ESI_CLIENT_ID_1=first_client_id
# ESI_CLIENT_SECRET_1=first_client_secret
# ESI_CLIENT_ID_2=second_client_id
# ESI_CLIENT_SECRET_2=second_client_secret
