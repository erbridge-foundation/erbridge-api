{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT a.id, a.name, a.owner_account_id, a.pending_delete_at, a.created_at, a.updated_at\n        FROM acl a\n        JOIN map_acl ma ON ma.acl_id = a.id\n        JOIN map m ON m.id = ma.map_id\n        WHERE ma.map_id = $1\n          AND m.deleted = false\n        ORDER BY a.name\n        ",
